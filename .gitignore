# dependencies
node_modules/
.bun/

# build output (glosa has no build step, but tools may emit these)
dist/
build/
*.tsbuildinfo

# glosa runtime state (never commit a user's workspace bus/provenance)
.glosa/
~/.glosa/

# logs / os
*.log
.DS_Store

# env / secrets
.env
.env.*

# session handoff (pause/restore) — never commit
.claude/session.md

# local agent/tool state (serena, impeccable etc.)
.conductor/settings.local.toml
.serena/
.impeccable/config.local.json
.impeccable/hook.cache.json
