{
  "name": "@davebream/glosa",
  "version": "0.1.0-alpha.0",
  "description": "Local-first writing and review workspace for people working with AI coding agents.",
  "license": "Apache-2.0",
  "author": "Dawid Leszczyński",
  "private": false,
  "type": "module",
  "bin": {
    "glosa": "packages/cli/src/main.ts"
  },
  "files": [
    "packages/cli/src",
    "packages/daemon/src",
    "packages/providers/claude-code/src",
    "packages/providers/codex/src",
    "packages/spa/src",
    "README.md",
    "ROADMAP.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "workspaces": ["packages/*", "packages/providers/*"],
  "os": ["darwin"],
  "cpu": ["arm64", "x64"],
  "engines": {
    "bun": ">=1.2.7"
  },
  "packageManager": "bun@1.2.7",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davebream/glosa.git"
  },
  "homepage": "https://github.com/davebream/glosa#readme",
  "bugs": {
    "url": "https://github.com/davebream/glosa/issues"
  },
  "keywords": [
    "ai-agents",
    "writing",
    "local-first",
    "claude-code",
    "codex",
    "markdown"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --changed --since origin/main --no-errors-on-unmatched",
    "lint:staged": "biome lint --staged --no-errors-on-unmatched",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "bun run lint && bun run typecheck && bun test",
    "setup:hooks": "lefthook install --reset-hooks-path",
    "audit:licenses": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow '0BSD;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;MIT;Python-2.0'",
    "package:check": "bun run scripts/package-smoke.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2",
    "@types/picomatch": "^4.0.3",
    "ajv": "^8.17.1",
    "happy-dom": "^20.11.0",
    "lefthook": "^2.1.10",
    "license-checker-rseidelsohn": "5.0.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@gunshi/plugin-completion": "0.37.1",
    "chokidar": "^5",
    "diff2html": "^3.4.56",
    "gunshi": "0.37.1",
    "idiomorph": "^0.7.4",
    "markdown-it": "^14.3.0",
    "picomatch": "^4.0.5"
  }
}
